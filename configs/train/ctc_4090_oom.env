# RTX 4090 OOM fallbacks for CTC training (lower batch duration / model size)
# Makefile: train-ctc-4090-oom, train-ctc-4090-sm

# ~120M model OOM preset
DATA_LOADER_TRAIN_MAX_BATCH_DURATION=180
DATA_LOADER_TRAIN_MAX_BATCH_SIZE=48
MODEL_ENCODER_D_MODEL=512

