# RTX 4090 preset — True Token-and-Duration Transducer (Phase 2)
# Requires use_tdt=true; init encoder from CTC/RNN-T checkpoint recommended
MODEL_ENCODER_D_MODEL=384
MODEL_ENCODER_N_LAYERS=16
MODEL_ENCODER_N_HEADS=8
DATA_LOADER_TRAIN_MAX_BATCH_DURATION=1200
PRECISION=bf16-mixed
MAX_EPOCHS=100
USE_TDT=true
TDT_SIGMA=0.05
TDT_OMEGA=0.1
RNNT_CLAMP=-1.0
COMPUTE_EVAL_LOSS=false
VAL_MAX_SYMBOLS_PER_T=10
JOINT_FUSED_BATCH_SIZE=4
SPEC_AUGMENT_START_EPOCH=16
AUDIO_AUGMENT_START_EPOCH=7
OPTIMIZER_LR=1e-3
