# RTX 4090 preset — Fast-Conformer CTC+Attention (~45M params, VRAM-limited)
# OOM fallback: train_max_batch_duration=400
MODEL_ENCODER_D_MODEL=256
MODEL_ENCODER_N_LAYERS=12
MODEL_ENCODER_N_HEADS=4
DATA_LOADER_TRAIN_MAX_BATCH_DURATION=600
PRECISION=bf16-mixed
MAX_EPOCHS=120
CTC_WEIGHT=0.3
AUX_CTC_WEIGHT=0.3
CTC_LABEL_SMOOTHING=0.1
MODEL_AUX_LAYER=5
SPEC_AUGMENT_START_EPOCH=16
AUDIO_AUGMENT_START_EPOCH=10
OPTIMIZER_LR=1e-3
OPTIMIZER_WARMUP_RATIO=0.15
