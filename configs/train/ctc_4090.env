# RTX 4090 preset — Fast-Conformer CTC (~120M params)
# OOM fallback: train_max_batch_duration=1200, d_model=384
MODEL_ENCODER_D_MODEL=512
MODEL_ENCODER_N_LAYERS=16
MODEL_ENCODER_N_HEADS=8
DATA_LOADER_TRAIN_MAX_BATCH_DURATION=1600
PRECISION=bf16-mixed
MAX_EPOCHS=100
CTC_LABEL_SMOOTHING=0.1
AUX_CTC_WEIGHT=0.3
MODEL_AUX_LAYER=7
SPEC_AUGMENT_START_EPOCH=16
AUDIO_AUGMENT_START_EPOCH=7
OPTIMIZER_LR=2e-3
OPTIMIZER_WARMUP_RATIO=0.1
