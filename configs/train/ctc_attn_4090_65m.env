# RTX 4090 — Fast-Conformer CTC+Attention 65M (init from CTC v9)
# OOM fallback: make train-ctc-attn-4090-65m-v9-oom (batch duration 400, batch 8)
MODEL_ENCODER_D_MODEL=400
MODEL_ENCODER_N_LAYERS=16
MODEL_ENCODER_N_HEADS=8
MODEL_ENCODER_CONV_KERNEL=9
MODEL_AUX_LAYER=8
DATA_TOKENIZER_MODEL=models/spm_unigram_2k_trainval.model
DATA_LOADER_TRAIN_MAX_BATCH_DURATION=400
DATA_LOADER_TRAIN_MAX_BATCH_SIZE=16
DATA_LOADER_LANGUAGE_BALANCE=equal_duration
PRECISION=bf16-mixed
MAX_EPOCHS=50
ACCUMULATE_GRAD_BATCHES=2
CTC_WEIGHT=0.3
AUX_CTC_WEIGHT=0.3
CTC_LABEL_SMOOTHING=0.0
SPEC_AUGMENT_TIME_MASKS=6
SPEC_AUGMENT_TIME_WIDTH_FRACTION=0.10
SPEC_AUGMENT_START_EPOCH=0
AUDIO_AUGMENT_START_EPOCH=0
AUDIO_AUGMENT_HEAVY_AUGMENT_START_EPOCH=0
AUDIO_AUGMENT_CLEAN_PASS_PROB=0.08
AUDIO_AUGMENT_BG_NOISE_PROB=0.25
AUDIO_AUGMENT_RIR_PROB=0.2
OPTIMIZER_LR=5e-4
OPTIMIZER_WARMUP_RATIO=0.10
OPTIMIZER_SCHEDULER=cosine
OPTIMIZER_COSINE_ETA_MIN=1e-5

# Resume fine-tune (make train-ctc-attn-4090-65m-v9-resume): best val_wer ckpt, 15 epochs
# OPTIMIZER_LR=2.5e-4
# OPTIMIZER_COSINE_ETA_MIN=5e-6
# MAX_EPOCHS=15

# Staged joint pipeline (make pipeline-joint-v9):
# Stage 1 warmup: DECODER_WARMUP_EPOCHS=5, MAX_EPOCHS=5, VAL_DECODE_MODE=attention_greedy
# Stage 2 joint: MAX_EPOCHS=40, CTC_WEIGHT=0.3, VAL_DECODE_MODE=ctc_greedy
# Stage 3 calibrate: CTC_CALIBRATION_EPOCHS=5, MAX_EPOCHS=5, CTC_WEIGHT=1.0, OPTIMIZER_LR=2.5e-4
