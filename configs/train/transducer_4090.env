# RTX 4090 — Fast-Conformer RNN-T / TDT transducer heads (4k tokenizer)
# Makefile: train-rnnt-4090, train-tdt-4090, train-rnnt-4090-oom
MODEL_ENCODER_D_MODEL=384
MODEL_ENCODER_N_LAYERS=16
MODEL_ENCODER_N_HEADS=8
DATA_TOKENIZER_MODEL=models/spm_unigram_4k_trainval.model
DATA_LOADER_TRAIN_MAX_BATCH_DURATION=1200
PRECISION=bf16-mixed
MAX_EPOCHS=100
RNNT_CLAMP=-1.0
FUSED_LOG_SOFTMAX=true
COMPUTE_EVAL_LOSS=false
VAL_MAX_SYMBOLS_PER_T=10
JOINT_FUSED_BATCH_SIZE=4
SPEC_AUGMENT_START_EPOCH=16
AUDIO_AUGMENT_START_EPOCH=7
OPTIMIZER_LR=1e-3
OPTIMIZER_WARMUP_RATIO=0.1
MUSAN_PATH=data/augment/noise_bank.pt
RIRS_PATH=data/augment/rir_bank.pt

# TDT-only (train-tdt-4090): add --use-tdt --tdt_sigma 0.05 --tdt_omega 0.1
# OOM fallback (train-rnnt-4090-oom): batch duration 800, joint_fused_batch_size=2
