# RTX 4090 preset — resume v3 @ ~ep22+ with milder aug + fresh cosine (50 ep)
CKPT_PATH=checkpoints/ctc_4090_65m_v3/last.ckpt
RESET_OPTIMIZER_STATE=true
MODEL_ENCODER_D_MODEL=400
MODEL_ENCODER_N_LAYERS=16
MODEL_ENCODER_N_HEADS=8
MODEL_ENCODER_CONV_KERNEL=9
MODEL_AUX_LAYER=8
DATA_TOKENIZER_MODEL=models/spm_unigram_2k_trainval.model
DATA_LOADER_TRAIN_MAX_BATCH_DURATION=1200
DATA_LOADER_TRAIN_MAX_BATCH_SIZE=64
ACCUMULATE_GRAD_BATCHES=2
PRECISION=bf16-mixed
MAX_EPOCHS=50
CTC_LABEL_SMOOTHING=0.0
AUX_CTC_WEIGHT=0.3
SPEC_AUGMENT_TIME_MASKS=2
SPEC_AUGMENT_TIME_WIDTH_FRACTION=0.05
SPEC_AUGMENT_START_EPOCH=0
AUDIO_AUGMENT_START_EPOCH=0
AUDIO_AUGMENT_HEAVY_AUGMENT_START_EPOCH=0
AUDIO_AUGMENT_BG_NOISE_PROB=0.25
AUDIO_AUGMENT_RIR_PROB=0.2
OPTIMIZER_LR=5e-4
OPTIMIZER_WARMUP_RATIO=0.05
OPTIMIZER_SCHEDULER=cosine
OPTIMIZER_COSINE_ETA_MIN=1e-5
MUSAN_PATH=data/augment/noise_bank.pt
RIRS_PATH=data/augment/rir_bank.pt
